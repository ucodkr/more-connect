{
  "name": "more-connect",
  "displayName": "More Connect",
  "description": "Database client for MySQL/MariaDB/PostgreSQL inside VS Code.",
  "version": "0.1.19",
  "publisher": "ucodkr",
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "mysql",
    "database",
    "mariadb"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node ./scripts/esbuild.mjs",
    "dev": "node ./scripts/esbuild.mjs --watch",
    "watch": "node ./scripts/esbuild.mjs --watch",
    "vsc:pac": "vsce package",
    "vsc:pub": "npm version patch -m \"release %s\" && vsce package && vsce publish"
  },
  "repository": "https://gitlab.com/ucodkr/tools/more-connect.git",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:moreConnect.addConnection",
    "onCommand:moreConnect.addOllamaConnection",
    "onCommand:moreConnect.addVsCodeFavorite",
    "onCommand:moreConnect.previewMarkdownFile",
    "onCommand:moreConnect.runQuery",
    "onCommand:moreConnect.openInternalBrowser",
    "onCommand:moreConnect.openExternalBrowser",
    "onCommand:moreConnect.openBrowserDevTools",
    "onView:moreConnectConnections"
  ],
  "main": "./dist/extension.js",
  "icon": "media/ucod.png",
  "contributes": {
    "configuration": {
      "title": "More Connect",
      "properties": {
        "moreConnect.connectionTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "Connection/SSH timeout in milliseconds before failing instead of waiting indefinitely."
        }
      }
    },
    "commands": [
      {
        "command": "moreConnect.addConnection",
        "title": "More Connect: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "moreConnect.editConnection",
        "title": "More Connect: Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "moreConnect.duplicateConnection",
        "title": "More Connect: Duplicate Connection",
        "icon": "$(copy)"
      },
      {
        "command": "moreConnect.removeConnection",
        "title": "More Connect: Remove Connection",
        "icon": "$(trash)"
      },
      {
        "command": "moreConnect.connect",
        "title": "More Connect: Connect",
        "icon": "$(plug)"
      },
      {
        "command": "moreConnect.disconnect",
        "title": "More Connect: Disconnect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "moreConnect.refreshSchema",
        "title": "More Connect: Refresh Schema",
        "icon": "$(sync)"
      },
      {
        "command": "moreConnect.previewTable",
        "title": "More Connect: Preview Table",
        "icon": "$(table)"
      },
      {
        "command": "moreConnect.runQuery",
        "title": "More Connect: Run Query",
        "icon": "$(play)"
      },
      {
        "command": "moreConnect.runQueryFromEditor",
        "title": "More Connect: Run Query (Selection/Current Line)",
        "icon": "$(run)"
      },
      {
        "command": "moreConnect.refreshConnections",
        "title": "More Connect: Refresh Connections",
        "icon": "$(refresh)"
      },
      {
        "command": "moreConnect.openSshTerminal",
        "title": "More Connect: Open SSH Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "moreConnect.importSshConfig",
        "title": "More Connect: Import ~/.ssh/config",
        "icon": "$(cloud-download)"
      },
      {
        "command": "moreConnect.addSshConnection",
        "title": "More Connect: Add SSH Connection",
        "icon": "$(add)"
      },
      {
        "command": "moreConnect.editSshConnection",
        "title": "More Connect: Edit SSH Connection",
        "icon": "$(edit)"
      },
      {
        "command": "moreConnect.removeSshConnection",
        "title": "More Connect: Remove SSH Connection",
        "icon": "$(trash)"
      },
      {
        "command": "moreConnect.addWebLink",
        "title": "More Connect: Add Web Link",
        "icon": "$(add)"
      },
      {
        "command": "moreConnect.addVsCodeFavorite",
        "title": "More Connect: Add VS Code Favorite",
        "icon": "$(add)"
      },
      {
        "command": "moreConnect.editVsCodeFavorite",
        "title": "More Connect: Edit VS Code Favorite",
        "icon": "$(edit)"
      },
      {
        "command": "moreConnect.removeVsCodeFavorite",
        "title": "More Connect: Remove VS Code Favorite",
        "icon": "$(trash)"
      },
      {
        "command": "moreConnect.openVsCodeFavorite",
        "title": "More Connect: Open VS Code Favorite (New Window)",
        "icon": "$(vscode)"
      },
      {
        "command": "moreConnect.openVsCodeFavoriteInFinder",
        "title": "More Connect: Open VS Code Favorite in Finder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "moreConnect.openVsCodeFavoriteInTerminal",
        "title": "More Connect: Open VS Code Favorite in Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "moreConnect.editWebLink",
        "title": "More Connect: Edit Web Link",
        "icon": "$(edit)"
      },
      {
        "command": "moreConnect.removeWebLink",
        "title": "More Connect: Remove Web Link",
        "icon": "$(trash)"
      },
      {
        "command": "moreConnect.addOllamaConnection",
        "title": "More Connect: Add Ollama Endpoint",
        "icon": "$(add)"
      },
      {
        "command": "moreConnect.editOllamaConnection",
        "title": "More Connect: Edit Ollama Endpoint",
        "icon": "$(edit)"
      },
      {
        "command": "moreConnect.removeOllamaConnection",
        "title": "More Connect: Remove Ollama Endpoint",
        "icon": "$(trash)"
      },
      {
        "command": "moreConnect.refreshOllamaModels",
        "title": "More Connect: Refresh Ollama Models",
        "icon": "$(refresh)"
      },
      {
        "command": "moreConnect.ollamaPullModel",
        "title": "More Connect: Ollama Pull Model",
        "icon": "$(cloud-download)"
      },
      {
        "command": "moreConnect.ollamaDeleteModel",
        "title": "More Connect: Ollama Delete Model",
        "icon": "$(trash)"
      },
      {
        "command": "moreConnect.ollamaChat",
        "title": "More Connect: Ollama Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "moreConnect.copyOllamaModelName",
        "title": "More Connect: Copy Ollama Model Name",
        "icon": "$(copy)"
      },
      {
        "command": "moreConnect.showOllamaModelInfo",
        "title": "More Connect: Show Ollama Model Info",
        "icon": "$(info)"
      },
      {
        "command": "moreConnect.openInternalBrowser",
        "title": "More Connect: Open Internal Browser",
        "icon": "$(globe)"
      },
      {
        "command": "moreConnect.openInternalBrowserFromLink",
        "title": "More Connect: Open Internal Browser (Saved Link)",
        "icon": "$(link-external)"
      },
      {
        "command": "moreConnect.openExternalBrowser",
        "title": "More Connect: Open External Browser",
        "icon": "$(browser)"
      },
      {
        "command": "moreConnect.openBrowserDevTools",
        "title": "More Connect: Open Browser Developer Tools",
        "icon": "$(tools)"
      },
      {
        "command": "moreConnect.previewMarkdownFile",
        "title": "More Connect: Preview Markdown (.md)",
        "icon": "$(markdown)"
      },
      {
        "command": "moreConnect.runSqlFile",
        "title": "More Connect: Run .sql File (Active Connection)",
        "icon": "$(play)"
      },
      {
        "command": "moreConnect.runSqlFromEditor",
        "title": "More Connect: Run SQL (Selection/Current Line)",
        "icon": "$(run)"
      },
      {
        "command": "moreConnect.showDatabaseInfo",
        "title": "More Connect: Database Info",
        "icon": "$(info)"
      },
      {
        "command": "moreConnect.showTableInfo",
        "title": "More Connect: Table Info",
        "icon": "$(info)"
      },
      {
        "command": "moreConnect.newSql",
        "title": "More Connect: New SQL",
        "icon": "$(file-code)"
      },
      {
        "command": "moreConnect.openSavedSql",
        "title": "More Connect: Open Saved SQL",
        "icon": "$(folder-opened)"
      },
      {
        "command": "moreConnect.saveSqlToGlobal",
        "title": "More Connect: Save SQL to Global Storage",
        "icon": "$(save)"
      },
      {
        "command": "moreConnect.addSqlFavoriteFromEditor",
        "title": "More Connect: Add SQL to Favorites",
        "icon": "$(star)"
      },
      {
        "command": "moreConnect.selectConnectionForSql",
        "title": "More Connect: Select Connection for .sql",
        "icon": "$(plug)"
      },
      {
        "command": "moreConnect.selectDatabaseForSql",
        "title": "More Connect: Select Database for .sql",
        "icon": "$(database)"
      },
      {
        "command": "moreConnect.generateTableDdl",
        "title": "More Connect: Generate Table DDL",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "moreConnect.runFavoriteSql",
        "title": "More Connect: Run Favorite SQL",
        "icon": "$(play)"
      },
      {
        "command": "moreConnect.setConnectionsStorageFolder",
        "title": "More Connect: Set Connections Storage Folder",
        "icon": "$(folder)"
      },
      {
        "command": "moreConnect.showStoragePaths",
        "title": "More Connect: Show Storage Paths",
        "icon": "$(folder-opened)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "moreConnectContainer",
          "title": "More Connect",
          "icon": "media/database.svg"
        }
      ]
    },
    "views": {
      "moreConnectContainer": [
        {
          "id": "moreConnectConnections",
          "name": "Connections"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "moreConnect.importSshConfig",
          "when": "view == moreConnectConnections",
          "group": "navigation"
        },
        {
          "command": "moreConnect.openInternalBrowser",
          "when": "view == moreConnectConnections",
          "group": "navigation"
        },
        {
          "command": "moreConnect.openExternalBrowser",
          "when": "view == moreConnectConnections",
          "group": "navigation"
        },
        {
          "command": "moreConnect.openBrowserDevTools",
          "when": "view == moreConnectConnections",
          "group": "navigation"
        },
        {
          "command": "moreConnect.setConnectionsStorageFolder",
          "when": "view == moreConnectConnections",
          "group": "navigation"
        },
        {
          "command": "moreConnect.refreshConnections",
          "when": "view == moreConnectConnections",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "moreConnect.addConnection",
          "when": "view == moreConnectConnections && viewItem == dbGroup",
          "group": "inline"
        },
        {
          "command": "moreConnect.addSshConnection",
          "when": "view == moreConnectConnections && viewItem == sshGroup",
          "group": "inline"
        },
        {
          "command": "moreConnect.addWebLink",
          "when": "view == moreConnectConnections && viewItem == webGroup",
          "group": "inline"
        },
        {
          "command": "moreConnect.addVsCodeFavorite",
          "when": "view == moreConnectConnections && viewItem == vscodeGroup",
          "group": "inline"
        },
        {
          "command": "moreConnect.addOllamaConnection",
          "when": "view == moreConnectConnections && viewItem == ollamaGroup",
          "group": "inline"
        },
        {
          "command": "moreConnect.newSql",
          "when": "view == moreConnectConnections && (viewItem == connection || viewItem == connectionConnected || viewItem == database || viewItem == table)",
          "group": "navigation"
        },
        {
          "command": "moreConnect.openSavedSql",
          "when": "view == moreConnectConnections && (viewItem == connection || viewItem == connectionConnected || viewItem == database || viewItem == table)",
          "group": "navigation"
        },
        {
          "command": "moreConnect.showDatabaseInfo",
          "when": "view == moreConnectConnections && viewItem == database",
          "group": "inline"
        },
        {
          "command": "moreConnect.connect",
          "when": "view == moreConnectConnections && viewItem == connection",
          "group": "inline"
        },
        {
          "command": "moreConnect.disconnect",
          "when": "view == moreConnectConnections && viewItem == connectionConnected",
          "group": "inline"
        },
        {
          "command": "moreConnect.runQuery",
          "when": "view == moreConnectConnections && viewItem == connectionConnected",
          "group": "inline"
        },
        {
          "command": "moreConnect.refreshSchema",
          "when": "view == moreConnectConnections && (viewItem == connection || viewItem == connectionConnected)",
          "group": "inline"
        },
        {
          "command": "moreConnect.editConnection",
          "when": "view == moreConnectConnections && (viewItem == connection || viewItem == connectionConnected)",
          "group": "navigation"
        },
        {
          "command": "moreConnect.duplicateConnection",
          "when": "view == moreConnectConnections && (viewItem == connection || viewItem == connectionConnected)",
          "group": "navigation"
        },
        {
          "command": "moreConnect.openSshTerminal",
          "when": "view == moreConnectConnections && viewItem == sshConnection",
          "group": "inline",
          "title": "Connect"
        },
        {
          "command": "moreConnect.editSshConnection",
          "when": "view == moreConnectConnections && viewItem == sshConnection",
          "group": "inline"
        },
        {
          "command": "moreConnect.removeSshConnection",
          "when": "view == moreConnectConnections && viewItem == sshConnection",
          "group": "navigation"
        },
        {
          "command": "moreConnect.openInternalBrowserFromLink",
          "when": "view == moreConnectConnections && viewItem == webLink",
          "group": "inline"
        },
        {
          "command": "moreConnect.openExternalBrowser",
          "when": "view == moreConnectConnections && viewItem == webLink",
          "group": "inline"
        },
        {
          "command": "moreConnect.openBrowserDevTools",
          "when": "view == moreConnectConnections && viewItem == webLink",
          "group": "navigation"
        },
        {
          "command": "moreConnect.editWebLink",
          "when": "view == moreConnectConnections && viewItem == webLink",
          "group": "navigation"
        },
        {
          "command": "moreConnect.removeWebLink",
          "when": "view == moreConnectConnections && viewItem == webLink",
          "group": "navigation"
        },
        {
          "command": "moreConnect.openVsCodeFavorite",
          "when": "view == moreConnectConnections && viewItem == vscodeFavorite",
          "group": "inline"
        },
        {
          "command": "moreConnect.openVsCodeFavoriteInFinder",
          "when": "view == moreConnectConnections && viewItem == vscodeFavorite",
          "group": "inline"
        },
        {
          "command": "moreConnect.openVsCodeFavoriteInTerminal",
          "when": "view == moreConnectConnections && viewItem == vscodeFavorite",
          "group": "inline"
        },
        {
          "command": "moreConnect.editVsCodeFavorite",
          "when": "view == moreConnectConnections && viewItem == vscodeFavorite",
          "group": "inline"
        },
        {
          "command": "moreConnect.removeVsCodeFavorite",
          "when": "view == moreConnectConnections && viewItem == vscodeFavorite",
          "group": "navigation"
        },
        {
          "command": "moreConnect.ollamaChat",
          "when": "view == moreConnectConnections && viewItem == ollamaConnection",
          "group": "inline"
        },
        {
          "command": "moreConnect.refreshOllamaModels",
          "when": "view == moreConnectConnections && viewItem == ollamaConnection",
          "group": "inline"
        },
        {
          "command": "moreConnect.ollamaPullModel",
          "when": "view == moreConnectConnections && viewItem == ollamaConnection",
          "group": "navigation"
        },
        {
          "command": "moreConnect.editOllamaConnection",
          "when": "view == moreConnectConnections && viewItem == ollamaConnection",
          "group": "navigation"
        },
        {
          "command": "moreConnect.removeOllamaConnection",
          "when": "view == moreConnectConnections && viewItem == ollamaConnection",
          "group": "navigation"
        },
        {
          "command": "moreConnect.ollamaChat",
          "when": "view == moreConnectConnections && viewItem == ollamaModel",
          "group": "inline"
        },
        {
          "command": "moreConnect.copyOllamaModelName",
          "when": "view == moreConnectConnections && viewItem == ollamaModel",
          "group": "inline"
        },
        {
          "command": "moreConnect.showOllamaModelInfo",
          "when": "view == moreConnectConnections && viewItem == ollamaModel",
          "group": "inline"
        },
        {
          "command": "moreConnect.ollamaDeleteModel",
          "when": "view == moreConnectConnections && viewItem == ollamaModel",
          "group": "navigation"
        },
        {
          "command": "moreConnect.removeConnection",
          "when": "view == moreConnectConnections && viewItem == connection",
          "group": "navigation"
        },
        {
          "command": "moreConnect.previewTable",
          "when": "view == moreConnectConnections && viewItem == table",
          "group": "inline"
        },
        {
          "command": "moreConnect.showTableInfo",
          "when": "view == moreConnectConnections && viewItem == table",
          "group": "inline"
        },
        {
          "command": "moreConnect.generateTableDdl",
          "when": "view == moreConnectConnections && viewItem == table",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "moreConnect.previewMarkdownFile",
          "when": "resourceExtname == .md",
          "group": "navigation"
        },
        {
          "command": "moreConnect.previewMarkdownFile",
          "when": "resourceExtname == .markdown",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "moreConnect.previewMarkdownFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "moreConnect.selectConnectionForSql",
          "when": "resourceLangId == sql",
          "group": "navigation"
        },
        {
          "command": "moreConnect.selectDatabaseForSql",
          "when": "resourceLangId == sql",
          "group": "navigation"
        },
        {
          "command": "moreConnect.runSqlFromEditor",
          "when": "resourceLangId == sql",
          "group": "navigation"
        },
        {
          "command": "moreConnect.runSqlFile",
          "when": "resourceLangId == sql",
          "group": "navigation"
        },
        {
          "command": "moreConnect.saveSqlToGlobal",
          "when": "resourceLangId == sql",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "moreConnect.previewMarkdownFile",
          "when": "resourceLangId == markdown"
        },
        {
          "command": "moreConnect.runQueryFromEditor",
          "when": "editorTextFocus"
        },
        {
          "command": "moreConnect.runQuery",
          "when": "editorTextFocus"
        },
        {
          "command": "moreConnect.openInternalBrowser"
        },
        {
          "command": "moreConnect.openExternalBrowser"
        },
        {
          "command": "moreConnect.openBrowserDevTools"
        },
        {
          "command": "moreConnect.addVsCodeFavorite"
        },
        {
          "command": "moreConnect.openVsCodeFavorite"
        },
        {
          "command": "moreConnect.openVsCodeFavoriteInFinder"
        },
        {
          "command": "moreConnect.openVsCodeFavoriteInTerminal"
        },
        {
          "command": "moreConnect.ollamaChat"
        },
        {
          "command": "moreConnect.ollamaPullModel"
        },
        {
          "command": "moreConnect.ollamaDeleteModel"
        },
        {
          "command": "moreConnect.copyOllamaModelName"
        },
        {
          "command": "moreConnect.showOllamaModelInfo"
        }
      ]
    },
    "keybindings": [
      {
        "command": "moreConnect.runSqlFromEditor",
        "key": "cmd+enter",
        "when": "editorTextFocus && resourceLangId == sql"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.10",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "mysql2": "^3.11.0",
    "pg": "^8.12.0",
    "ssh2": "^1.16.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
