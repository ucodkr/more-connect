{
  "name": "more-connect",
  "displayName": "More Connect",
  "description": "More Connect is a VS Code extension for working with databases, servers, REST APIs, Docker hosts, web links, and local development tools from one sidebar",
  "version": "0.1.34",
  "publisher": "ucodkr",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui"
  ],
  "keywords": [
    "mysql",
    "sqlite",
    "database",
    "oracle",
    "mariadb",
    "docker",
    "ssh",
    "rest api",
    "llm"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node ./scripts/esbuild.mjs",
    "dev": "node ./scripts/esbuild.mjs --watch",
    "watch": "node ./scripts/esbuild.mjs --watch",
    "vsc:pac": "vsce package",
    "vsc:pub": "npm version patch -m \"release %s\" && vsce package && vsce publish"
  },
  "repository": "https://gitlab.com/ucodkr/tools/more-connect.git",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:moreConnect.addConnection",
    "onCommand:moreConnect.addOllamaConnection",
    "onCommand:moreConnect.addVsCodeFavorite",
    "onCommand:moreConnect.previewMarkdownFile",
    "onCommand:moreConnect.runQuery",
    "onCommand:moreConnect.openInternalBrowser",
    "onCommand:moreConnect.openExternalBrowser",
    "onCommand:moreConnect.openBrowserDevTools",
    "onCommand:moreConnect.openRestClient",
    "onCommand:moreConnect.addRestCollection",
    "onCommand:moreConnect.addRestRequest",
    "onCommand:moreConnect.addDockerHost",
    "onCommand:moreConnect.addS3Host",
    "onCommand:moreConnect.uploadS3",
    "onCommand:moreConnect.uploadS3File",
    "onCommand:moreConnect.uploadS3Folder",
    "onCommand:moreConnect.createS3Folder",
    "onCommand:moreConnect.copyS3Link",
    "onCommand:moreConnect.openSshFileExplorer",
    "onCommand:moreConnect.openSshFolderInVsCode",
    "onCommand:moreConnect.addSshFolder",
    "onView:moreConnectConnections"
  ],
  "main": "./dist/extension.js",
  "icon": "media/ucod.png",
  "contributes": {
    "configuration": {
      "title": "More Connect",
      "properties": {
        "moreConnect.connectionTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "Connection/SSH timeout in milliseconds before failing instead of waiting indefinitely."
        },
        "moreConnect.restGlobalStorageFolder": {
          "type": "string",
          "default": "",
          "description": "Folder path to store More Connect REST data files (more.rest.json, more.rest.history.json). Leave empty to use VS Code global storage."
        }
      }
    },
    "commands": [
